POSTGRES_DB=sistema_kettal
POSTGRES_USER=kettal
POSTGRES_PASSWORD=kettal_dev_123

# Para correr la app fuera de Docker
DATABASE_URL=postgresql://kettal:kettal_dev_123@localhost:5433/sistema_kettal?schema=public

# Ruta del host donde se guardan los backups (lado izquierdo del volumen Docker)
# En Windows puede ser: C:\Users\...\OneDrive\Backups
# Se actualiza automáticamente desde la configuración inicial del sistema
BACKUP_PATH=./backups
